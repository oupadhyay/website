---
// [...slug].astro — Dynamic route for individual writing posts.
// Renders MDX content within the Post layout.
import { getCollection, render } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  // External entries (papers with a `url`) link out — no internal page.
  return posts
    .filter(post => !post.data.url)
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Post title={post.data.title} date={post.data.date} description={post.data.description}>
  <Content />
</Post>
