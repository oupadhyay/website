---
// index.astro — Home page: bio, featured projects, recent writing, elsewhere links, footer.
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import WritingEntry from '../components/WritingEntry.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

// Pull thoughts/papers from the same content collection the /thoughts page uses,
// so both views stay consistent. Show the most recent few here.
const recentThoughts = (await getCollection('thoughts'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const month = d.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' });
  const year = d.getUTCFullYear().toString().slice(2);
  return `${month} '${year}`;
}
---
<Base title="Ojasw Upadhyay">
  <!-- Bio -->
  <section>
    <h1 style="font-family: var(--font-serif); color: var(--color-text-primary); font-size: 3.75rem; letter-spacing: -0.025em; line-height: 1.1; margin-bottom: 0.5rem">
      Ojasw Upadhyay
    </h1>
    <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 1.5rem">
      Software Engineer at YouTube · Georgia Tech '25
    </p>
    <p style="margin-bottom: 0">
      I build things at the intersection of AI, design, and intuitive interfaces.
      Currently working on AI Dubbing at
      <a class="inline-link" href="https://youtube.com" style="--deco-color: var(--deco-red)">YouTube</a>.
      Previously: two internships at
      <a class="inline-link" href="https://google.com" style="--deco-color: var(--deco-lime)">Google</a>,
      and AI safety research at
      <a class="inline-link" href="https://gatech.edu" style="--deco-color: var(--deco-yellow)">Georgia Tech</a>.
    </p>
  </section>

  <!-- Projects -->
  <section style="margin-top: var(--section-gap)">
    <SectionHeader label="Projects" />
    <div class="grid grid-cols-1 sm:grid-cols-2" style="gap: var(--card-gap)">
      {projects.map(project => (
        <ProjectCard
          title={project.title}
          description={project.description}
          href={project.href}
          tags={project.tags}
        />
      ))}
    </div>
  </section>

  <!-- Thoughts -->
  <section style="margin-top: var(--section-gap)">
    <SectionHeader label="Thoughts" />
    <div>
      {recentThoughts.map(post => (
        <WritingEntry
          title={post.data.title}
          date={formatDate(post.data.date)}
          href={post.data.url ?? `/thoughts/${post.id}`}
          external={!!post.data.url}
          tags={post.data.tags ?? []}
          tagTooltips={post.data.tagTooltips ?? {}}
        />
      ))}
    </div>
  </section>

  <Footer />
</Base>
