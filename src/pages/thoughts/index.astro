---
// thoughts/index.astro — Thoughts page with year-grouped timeline.
import Base from '../../layouts/Base.astro';
import WritingEntry from '../../components/WritingEntry.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('thoughts');

// Sort by date descending
const sorted = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Group by year. Use UTC so a date like "2025-06-01" (parsed as UTC midnight)
// is not shifted into the previous day/year when the build runs in a timezone
// behind UTC.
const byYear = sorted.reduce((acc, post) => {
  const year = new Date(post.data.date).getUTCFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof sorted>);

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

// Format date as "Mon 'YY" in UTC to match the authored date exactly.
function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const month = d.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' });
  const year = d.getUTCFullYear().toString().slice(2);
  return `${month} '${year}`;
}

---
<Base title="Thoughts — Ojasw Upadhyay" description="Notes on AI, engineering, and building things.">
  <h1 style="font-family: var(--font-serif); font-size: 1.875rem; font-weight: 400; letter-spacing: -0.025em; line-height: 1.3; color: var(--color-text-primary); margin-bottom: 2rem">
    Thoughts
  </h1>

  {years.map(year => (
    <section style="margin-bottom: 2rem">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 0.5rem; letter-spacing: 0.05em">
        {year}
      </p>
      {byYear[year].map(post => (
        <WritingEntry
          title={post.data.title}
          date={formatDate(post.data.date)}
          href={post.data.url ?? `/thoughts/${post.id}`}
          external={!!post.data.url}
          tags={post.data.tags ?? []}
          tagTooltips={post.data.tagTooltips ?? {}}
        />
      ))}
    </section>
  ))}

  <Footer />
</Base>
