---
// Post.astro — Layout for individual writing/blog posts.
// Inherits from Base. Adds back link, title, date, and prose-styled slot.

interface Props {
  title: string;
  date: string;
  description?: string;
}

const { title, date, description } = Astro.props;
import Base from './Base.astro';
import 'katex/dist/katex.min.css';
---
<Base title={`${title} — Ojasw Upadhyay`} description={description}>
  <article>
    <header style="margin-bottom: 2rem">
      <a href="/writing" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); text-decoration: none; display: inline-block; margin-bottom: 1rem; transition: color 200ms ease"
         onmouseover="this.style.color='var(--color-text-primary)'"
         onmouseout="this.style.color='var(--color-text-muted)'">
        ← Writing
      </a>
      <h1 style="font-family: var(--font-serif); font-size: 1.875rem; letter-spacing: -0.025em; line-height: 1.3; color: var(--color-text-primary); margin-bottom: 0.5rem">
        {title}
      </h1>
      <time style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted)">
        {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
      </time>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style is:global>
  /* Prose styling for MDX content */
  .prose {
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: none;
  }
  .prose p {
    margin-bottom: 1.25rem;
  }
  .prose a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border);
    transition: text-decoration-color 200ms ease;
  }
  .prose a:hover {
    text-decoration-color: var(--color-text-muted);
  }
  .prose h2 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface-2);
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
  }
  .prose pre {
    background: var(--color-surface-1);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }
  .prose pre code {
    background: none;
    padding: 0;
    border-radius: 0;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose li {
    margin-bottom: 0.25rem;
  }
  .prose img {
    border-radius: 8px;
    margin: 1.5rem 0;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  /* KaTeX display math: allow horizontal scroll on overflow */
  .prose .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
    margin: 1.5rem 0;
  }
  /* Mermaid diagrams render client-side into this block */
  .prose pre.mermaid {
    background: none;
    border: none;
    padding: 0;
    text-align: center;
    margin: 1.5rem 0;
    /* Hide raw diagram source until mermaid renders it */
    color: transparent;
  }
  .prose pre.mermaid[data-processed] {
    color: inherit;
  }
</style>

<script>
  // Lazily render Mermaid diagrams only on pages that contain them, so the
  // ~500KB library never loads elsewhere. Re-runs after view transitions.
  async function renderMermaid() {
    const nodes = document.querySelectorAll<HTMLElement>('pre.mermaid:not([data-processed])');
    if (nodes.length === 0) return;
    const { default: mermaid } = await import('mermaid');
    const theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'neutral' : 'dark';
    mermaid.initialize({ startOnLoad: false, theme, securityLevel: 'strict' });
    await mermaid.run({ nodes });
  }
  document.addEventListener('astro:page-load', renderMermaid);
</script>
