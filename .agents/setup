#!/usr/bin/env bash
set -euo pipefail

PNPM_VERSION="$(node -p "require('./package.json').engines.pnpm")"
export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
export PATH="$PNPM_HOME/bin:$PATH"

# The standalone pnpm binary can install Node even when an orb's system Node is
# older than this project's requirement.
if [[ ! -x "$PNPM_HOME/bin/pnpm" ]] || [[ "$("$PNPM_HOME/bin/pnpm" --version)" != "$PNPM_VERSION" ]]; then
  curl -fsSL https://get.pnpm.io/install.sh | env PNPM_VERSION="$PNPM_VERSION" SHELL=/bin/bash bash -
fi

pnpm runtime set node 22 -g
pnpm install --frozen-lockfile
